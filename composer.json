{
  "name": "keeal/keeal-php",
  "version": "0.2.0",
  "description": "Keeal PHP SDK — hosted checkout REST API client",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Keeal\\Checkout\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Keeal\\Checkout\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
